<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Solu1StoreCredit\Core\Content\StoreCredit\StoreCreditDefinition" public="true">
            <tag name="shopware.entity.definition" entity="solu1_store_credit" />
        </service>

        <service id="Solu1StoreCredit\Core\Content\StoreCreditHistory\StoreCreditHistoryDefinition">
            <tag name="shopware.entity.definition" entity="solu1_store_credit_history" />
        </service>

        <service id="Solu1StoreCredit\Service\StoreCreditManager">
            <argument type="service" id="solu1_store_credit.repository"/>
            <argument type="service" id="solu1_store_credit_history.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="Solu1StoreCredit\Service\OrderStateInstaller">
            <argument type="service" id="state_machine.repository" />
            <argument type="service" id="state_machine_state.repository" />
            <argument type="service" id="state_machine_transition.repository" />
            <argument type="service" id="state_machine_history.repository" />
        </service>

        <service id="Solu1StoreCredit\Controller\StoreCreditController">
            <argument type="service" id="Solu1StoreCredit\Service\StoreCreditManager" />
            <argument type="service" id="logger"/>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="Solu1StoreCredit\Controller\StoreCreditPageController">
            <argument type="service" id="solu1_store_credit.repository"/>
            <argument type="service" id="solu1_store_credit_history.repository"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <call method="setTwig">
                <argument type="service" id="twig"/>
            </call>
        </service>

        <service id="Solu1StoreCredit\Subscriber\CartSubscriber">
                <argument type="service" id="Solu1StoreCredit\Service\StoreCreditManager"/>
                <argument type="service" id="logger"/>
                <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Solu1StoreCredit\Subscriber\OrderRefundSubscriber" public="true">
            <argument type="service" id="order.repository" />
            <argument type="service" id="order_return.repository" on-invalid="null"/>
            <argument type="service" id="Solu1StoreCredit\Service\StoreCreditManager" />
            <argument type="service" id="logger"/>
            <tag name="kernel.event_subscriber" />
        </service>

        <service id="Solu1StoreCredit\Storefront\Controller\StoreCreditApplyController">
            <argument type="service" id="Shopware\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="solu1_store_credit.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="Solu1StoreCredit\EventSubscriber\StoreCreditCheckoutSubscriber">
            <argument type="service" id="Solu1StoreCredit\Service\StoreCreditManager"/>
            <argument type="service" id="Shopware\Core\Checkout\Cart\SalesChannel\CartService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Solu1StoreCredit\Command\OrderStateInstallerCommand">
            <argument type="service" id="Solu1StoreCredit\Service\OrderStateInstaller"/>
            <tag name="console.command" command="store-credit:install-order-state" />
        </service>

        <service id="Solu1StoreCredit\Subscriber\ConfigCommandSubscriber">
            <argument type="service" id="console.command_loader"/>
            <argument type="service" id="logger"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Solu1StoreCredit\Core\Checkout\Cart\Processor\ValidateStoreCreditCartProcessor">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <tag name="shopware.cart.processor" priority="-20000"/>
        </service>

        
    </services>
</container>